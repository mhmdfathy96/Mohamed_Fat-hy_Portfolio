# Google Analytics 4 — Measurement ID (format: G-XXXXXXXXXX)
# Get it from: https://analytics.google.com → Admin → Data Streams → Web stream
# Leave unset locally to skip GA4 in development.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity — Project ID (the alphanumeric string from the tracking snippet)
# Get it from: https://clarity.microsoft.com → Settings → Setup → "clarity.ms/tag/<ID>"
# Leave unset locally to skip Clarity in development.
NEXT_PUBLIC_CLARITY_PROJECT_ID=
